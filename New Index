<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Golf Drill Library</title>

<style>

:root{
--bg:#f4f4f4;
--card:#ffffff;
--text:#222;
--border:#ddd;
}

body.dark{
--bg:#1e1e1e;
--card:#2c2c2c;
--text:#f1f1f1;
--border:#444;
}

body{
font-family:Arial;
background:var(--bg);
color:var(--text);
margin:0;
padding:20px;
transition:.3s;
}

h1{
text-align:center;
margin-bottom:10px;
}

.controls{
display:flex;
justify-content:center;
gap:10px;
margin-bottom:25px;
flex-wrap:wrap;
}

input{
padding:10px;
border-radius:6px;
border:1px solid var(--border);
width:220px;
}

button{
padding:10px 14px;
border:none;
border-radius:6px;
cursor:pointer;
font-weight:bold;
}

.toggle{
background:#444;
color:white;
}

.section{
margin-bottom:40px;
}

.section-title{
font-size:22px;
cursor:pointer;
border-bottom:2px solid var(--border);
padding-bottom:6px;
margin-bottom:15px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:18px;
}

.video-card{
background:var(--card);
padding:16px;
border-radius:10px;
box-shadow:0 3px 6px rgba(0,0,0,.15);
position:relative;
}

.video-label{
font-weight:bold;
margin-bottom:12px;
min-height:40px;
}

.button{
display:inline-block;
padding:10px 14px;
border-radius:6px;
color:white;
text-decoration:none;
font-weight:bold;
}

.youtube{background:#ff0000;}
.facebook{background:#1877f2;}
.instagram{background:#e1306c;}

.favorite{
position:absolute;
top:8px;
right:10px;
cursor:pointer;
font-size:18px;
}

.favorite.active{
color:gold;
}

.topBtn{
position:fixed;
bottom:20px;
right:20px;
background:#333;
color:white;
padding:10px 14px;
border-radius:8px;
cursor:pointer;
display:none;
}

</style>
</head>

<body>

<h1>Golf Drill Library</h1>

<div class="controls">
<input id="search" placeholder="Search drills...">
<button class="toggle" onclick="toggleDark()">Dark Mode</button>
</div>

<div id="library"></div>

<div class="topBtn" id="topBtn" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑ Top</div>

<script>

const drills=`

"New Ones To Try"
Shoulder - https://www.facebook.com/share/r/1BifyXN4MN/
Step & stretch - https://www.facebook.com/share/r/1AsX6MFiHM/
Swing thoughts for knee - https://www.facebook.com/share/r/17A17TxKa2/
Stick under arm - https://www.facebook.com/share/r/18C8KNsT5s/
Compression Load Foot - https://www.facebook.com/share/r/18CNtqXDmu/
MIT drill - https://www.facebook.com/share/r/1AmwB3pgJE/
Hips - https://www.facebook.com/share/r/17oRo2jBv8/
Chipping - https://www.facebook.com/share/r/17xozQ9UJB/
Weight Shift - https://www.facebook.com/share/r/16qGJYwMzZ/

"Stick Drills"
Early Extension (Stick) - https://www.facebook.com/share/r/1C3ifTvfNJ/
Shoulders (Stick) - https://www.facebook.com/share/r/1BfbG992GG/
Side Bending (Sticks) - https://www.facebook.com/share/v/1DM4U4N2xJ/
Stay down (Stick Drill) - https://www.facebook.com/share/r/1BvBY6XJQB/
Timing Drill - Stick In Belt Loops - https://youtube.com/shorts/rs3F2hvJuFc

"Compression Drills"
Compression Position Drill - https://www.facebook.com/share/v/1AMveCXnvh/
Compression Feels Like - https://youtube.com/shorts/J6DSw7Z-fQs
Compression - https://www.facebook.com/share/r/1YgX8mCUpJ/
Compression Drill - https://www.facebook.com/share/r/1A3zPZ5z1k/
Compression Drill - https://youtube.com/shorts/qx-q3Dtg4DI

`;

const container=document.getElementById("library");
const favorites=JSON.parse(localStorage.getItem("favorites")||"[]");

let grid;

drills.trim().split("\n").forEach(line=>{

line=line.trim();
if(!line) return;

if(line.startsWith('"')){
const section=document.createElement("div");
section.className="section";

const title=line.replace(/"/g,"");

const heading=document.createElement("div");
heading.className="section-title";
heading.textContent=title;

grid=document.createElement("div");
grid.className="grid";

heading.onclick=()=>grid.classList.toggle("hide");

section.appendChild(heading);
section.appendChild(grid);
container.appendChild(section);

return;
}

const parts=line.split(" - ");
if(parts.length<2) return;

const label=parts[0];
const url=parts[1];

let platform="youtube";
let text="Watch";

if(url.includes("facebook")){
platform="facebook";
text="Facebook";
}
if(url.includes("instagram")){
platform="instagram";
text="Instagram";
}
if(url.includes("youtube")){
platform="youtube";
text="YouTube";
}

const card=document.createElement("div");
card.className="video-card";

const fav=document.createElement("div");
fav.className="favorite";
fav.innerHTML="★";

if(favorites.includes(label)) fav.classList.add("active");

fav.onclick=()=>{
fav.classList.toggle("active");

let list=JSON.parse(localStorage.getItem("favorites")||"[]");

if(list.includes(label)){
list=list.filter(x=>x!==label);
}else{
list.push(label);
}

localStorage.setItem("favorites",JSON.stringify(list));
};

card.innerHTML=`
<div class="video-label">${label}</div>
<a href="${url}" target="_blank" class="button ${platform}">
Watch on ${text}
</a>
`;

card.appendChild(fav);

grid.appendChild(card);

});

document.getElementById("search").addEventListener("input",function(){

const term=this.value.toLowerCase();

document.querySelectorAll(".video-card").forEach(card=>{
const text=card.innerText.toLowerCase();
card.style.display=text.includes(term)?"block":"none";
});

});

function toggleDark(){
document.body.classList.toggle("dark");
}

window.addEventListener("scroll",()=>{
document.getElementById("topBtn").style.display=
window.scrollY>400?"block":"none";
});

</script>

</body>
</html>
